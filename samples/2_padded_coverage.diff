--- a/auth/session.py
+++ b/auth/session.py
@@ -22,6 +22,10 @@ def validate_session_token(token: str) -> bool:
     Validates a session token against the active session store.
     Returns True if valid, False otherwise.
     """
+    if not token:
+        return False
+    if len(token) < 8:
+        return False
     return token in _SESSION_STORE
